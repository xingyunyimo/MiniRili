<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#FFF8E1">

    <!-- 年月标题行 + 翻页 -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/widget_prev"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@android:color/transparent"
            android:contentDescription="上月" />

        <TextView
            android:id="@+id/widget_month_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:text="2026年7月" />

        <ImageButton
            android:id="@+id/widget_next"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_media_next"
            android:background="@android:color/transparent"
            android:contentDescription="下月" />
    </LinearLayout>

    <!-- 星期行 -->
    <LinearLayout
        android:id="@+id/widget_weekday_row"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="日" android:textSize="11sp" android:textColor="#999999" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="一" android:textSize="11sp" android:textColor="#999999" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="二" android:textSize="11sp" android:textColor="#999999" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="三" android:textSize="11sp" android:textColor="#999999" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="四" android:textSize="11sp" android:textColor="#999999" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="五" android:textSize="11sp" android:textColor="#999999" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="六" android:textSize="11sp" android:textColor="#999999" />
    </LinearLayout>

    <!-- 日期网格容器（动态填充，最多 6 行 × 7 列） -->
    <LinearLayout
        android:id="@+id/widget_calendar_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical" />

    <!-- 今日事件摘要 -->
    <TextView
        android:id="@+id/widget_event_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:textSize="12sp"
        android:textColor="#666666"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="暂无事件" />

</LinearLayout>