<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/combined_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="6dp"
    android:background="@drawable/widget_combined_bg">

    <!-- ===== 第一行：日期 + 时间 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:maxLines="1"
            android:text="7月12日" />

        <TextView
            android:layout_width="6dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/widget_weekday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#1A1A1A"
            android:text="星期六" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/widget_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:text="14:30" />
    </LinearLayout>

    <!-- ===== 第二行：农历 + 节假日 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_lunar_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="10sp"
            android:textColor="#666666"
            android:maxLines="1"
            android:text="五月初五" />

        <TextView
            android:id="@+id/widget_holiday_tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#E53935"
            android:visibility="gone"
            android:text="端午节" />

        <TextView
            android:id="@+id/widget_weather_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="☀" />

        <TextView
            android:id="@+id/widget_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:text="32°" />
    </LinearLayout>

    <!-- ===== 分割线 ===== -->
    <TextView
        android:id="@+id/widget_divider_top"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="1dp"
        android:background="#33000000" />

    <!-- 底部分割线（Provider 代码引用，实际隐藏） -->
    <TextView
        android:id="@+id/widget_divider_bottom"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- 城市名（Provider 代码引用，隐藏） -->
    <TextView
        android:id="@+id/widget_city"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- ===== 第三行：天气描述 + 事件信息 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical">

        <!-- 天气描述 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_weather_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="10sp"
                android:textColor="#666666"
                android:maxLines="1"
                android:text="晴" />

            <TextView
                android:id="@+id/widget_feels_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#666666"
                android:text="体感 30°" />

            <TextView
                android:layout_width="4dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/widget_aqi_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#4CAF50"
                android:text="优" />

            <TextView
                android:layout_width="2dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/widget_aqi_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#4CAF50"
                android:text="AQI 42" />

            <TextView
                android:id="@+id/widget_weather_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#999999"
                android:visibility="gone"
                android:text="天气暂不可用" />
        </LinearLayout>

        <!-- 事件行 -->
        <LinearLayout
            android:id="@+id/widget_event_row"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_event_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:maxLines="1"
                android:text="今日 0 项事件" />

            <TextView
                android:id="@+id/widget_event_color"
                android:layout_width="4dp"
                android:layout_height="12dp"
                android:background="#4CAF50"
                android:visibility="gone" />

            <TextView
                android:layout_width="3dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/widget_event_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#666666"
                android:visibility="gone"
                android:text="09:00" />

            <TextView
                android:id="@+id/widget_event_time_space"
                android:layout_width="4dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_event_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:textColor="#1A1A1A"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"
                android:text="" />

            <TextView
                android:id="@+id/widget_event_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#999999"
                android:text="暂无事件，点击新建" />

            <TextView
                android:id="@+id/widget_new_event"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#666666"
                android:text="+" />

            <TextView
                android:id="@+id/widget_bg_toggle"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="#666666"
                android:text="◇" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>